# ── Collaris Environment Variables ─────────────────────────────────────────
# Copy to .env and fill in real values before running.

# Database — defaults to SQLite for zero-setup dev; switch to PostgreSQL in production
# DATABASE_URL=postgresql://collaris:password@localhost:5432/collaris
DATABASE_URL=sqlite:///./collaris.db

# Cache
REDIS_URL=redis://localhost:6379

# External data
FRED_API_KEY=

# Runtime
ENVIRONMENT=development
REFRESH_INTERVAL_MIN=5

# Risk thresholds (used everywhere — never hardcode these)
BREACH_THRESHOLD=85
WARNING_THRESHOLD=65

# Agent
AGENT_MODEL=gpt-4o-mini
AGENT_MAX_TOKENS=1000
AGENT_LOOP_INTERVAL_SEC=300
